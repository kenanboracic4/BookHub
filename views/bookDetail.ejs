<!DOCTYPE html>
<html>

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel="stylesheet" href="/stylesheets/bookDetail.css" />
    <link rel="stylesheet" href="/stylesheets/footer.css" />
</head>

<body>

    <% include partials/header %>

        <div class="bd-main-wrapper">

            <div class="bd-card">

                <div class="bd-layout">
                    <div class="bd-image-col">
                        <div class="bd-image-wrapper">
                            <div class="book-status">
                                <%= book.status %>
                            </div>
                            <img src="<%= book.imageUrl %>" alt="<%= book.title %>">

                        </div>

                    </div>

                    <div class="bd-info-col">

                        <div class="bd-header">
                            <h1 class="bd-title">
                                <%= book.title %>
                            </h1>
                            <p class="bd-author">Autor: <span>
                                    <%= book.author %>
                                </span></p>

                            <div class="bd-meta-row">
                                <div class="bd-rating">
                                    <i id="bd-rating-i" class="fa-solid fa-star"></i>
                                    <%= book.averageRating %> / 5
                                </div>
                                <div class="bd-views">
                                    <i class="fa fa-eye"></i>
                                    <%= book.viewCount %> pregleda
                                </div>
                            </div>

                            <div class="bd-price">
                                <%= parseFloat(book.price).toFixed(2) %> KM
                            </div>
                        </div>

                        <div class="bd-data-grid">
                            <div class="bd-input-group">
                                <label>Žanr</label>
                                <div class="bd-value-field">
                                    <%= (book.genre && book.genre.name) ? book.genre.name : 'Nije navedeno' %>
                                </div>
                            </div>

                            <div class="bd-input-group">
                                <label>Stanje</label>
                                <div class="bd-value-field">
                                    <%= (book.condition && book.condition.name) ? book.condition.name : 'Nije navedeno'
                                        %>
                                </div>
                            </div>

                            <div class="bd-input-group">
                                <label>Lokacija</label>
                                <div class="bd-value-field">
                                    <%= (book.location && book.location.name) ? book.location.name : 'Nije navedeno' %>
                                </div>
                            </div>

                            <div class="bd-input-group">
                                <label>Jezik</label>
                                <div class="bd-value-field">
                                    <%= (book.language && book.language.name) ? book.language.name : 'Nije navedeno' %>
                                </div>
                            </div>

                            <div class="bd-input-group bd-full-width-mobile">
                                <label>Moguća zamjena</label>
                                <div class="bd-value-field bd-exchange-field">
                                    <% if (book.isForExchange) { %>
                                        <i class="fa-solid fa-check-circle" style="color: #16a34a;"></i> Da
                                        <% } else { %>
                                            <i class="fa-solid fa-circle-xmark" style="color: #ef4444;"></i> Ne
                                            <% } %>
                                </div>

                            </div>
                            <% if(user && user.role == 'Kupac'){ %>
                            <div class="bd-input-group bd-report-align">
                                <label>Žalba</label> <button type="button" class="btn-report-user-new"
                                    onclick="openReportModal()">
                                    <i class="fa-solid fa-flag"></i> Prijavi oglas
                                </button>
                            </div>
                            <% } %>
                        </div>

                        <div class="bd-description">
                            <h3>O knjizi</h3>
                            <p>
                                <%= book.description %>
                            </p>
                        </div>

                        <div class="bd-seller-box">
                            <div class="bd-seller-avatar">
                                <img class="avatar-circle-profile"
                                    src="<%=(book.seller.profileImage && book.seller.profileImage.length > 0) ? book.seller.profileImage : '/images/noProfileImage.png' %>"
                                    alt="<%= book.seller.firstName %> <%= book.seller.lastName %>">
                            </div>
                            <div class="bd-seller-info">
                                <span class="bd-seller-label">Prodavač</span>
                                <a href="/user/profile/<%= book.sellerId  %>" class="bd-seller-name">
                                    <%= (book.seller) ? book.seller.firstName + ' ' + book.seller.lastName : 'Nepoznato'
                                        %>
                                </a>
                            </div>
                            <div class="bd-post-date">

                                <i class="fa-regular fa-calendar"></i>
                                <%= new Date(book.createdAt).toLocaleDateString('bs-BA') %>
                            </div>
                        </div>

                        <% if(user && user.role=='Kupac' ) { %>
                            <div class="bd-actions">
                                <button class="bd-btn bd-btn-primary btn-buy-book" data-id="<%= book.id %>">
                                    <i class="fa fa-shopping-cart"></i> Dodaj u korpu
                                </button>
                                <a href="/chat/inbox/<%=book.id %>/<%= book.sellerId %>" class="bd-btn bd-btn-outline">
                                    <i class="fa fa-envelope"></i> Kontakt
                                </a>
                            </div>
                            <% } %>

                             <div class="bd-input-group bd-report-align">
                                <label>Komentari</label> <button type="button" class="btn-comment-book"
                                    onclick="openCommentModal()">
                                    <i class="fa-solid fa-flag"></i> Komentari
                                </button>
                            </div>
                    </div>
                </div>
            </div>
        </div>


        <div id="reportModal" class="report-modal-overlay" style="display: none;">
    <div class="report-modal-card">
        <div class="modal-header">
            <h4><i class="fa-solid fa-triangle-exclamation"></i> Prijavi oglas</h4>
            <button class="close-modal" onclick="closeReportModal()">&times;</button>
        </div>
        <form id="reportForm">
            <input type="hidden" name="targetId" value="<%= book.id %>">
            
            <div class="form-group">
                <label>Razlog prijave:</label>
                <select name="reason" required>
                    <option value="">Odaberite razlog...</option>
                    <option value="Prevara">Prevara / Lažni podaci</option>
                    <option value="Neprikladan sadržaj">Neprikladan sadržaj ili slike</option>
                    <option value="Pogrešna kategorija">Pogrešna kategorija/žanr</option>
                    <option value="Ostalo">Ostalo</option>
                </select>
            </div>
            <div class="form-group">
                <label>Detaljan opis:</label>
                <textarea name="description" placeholder="Objasnite zašto prijavljujete ovaj oglas..." required></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="closeReportModal()">Odustani</button>
                <button type="submit" class="btn-danger">Pošalji prijavu</button>
            </div>
        </form>
    </div>
</div>

<div id="commentModal" class="report-modal-overlay" style="display: none;">
    <div class="comment-modal-card">
        
        <div class="modal-header" style="padding: 20px 25px; border-bottom: 1px solid #f1f5f9;">
            <h4 style="margin:0; font-size: 1.1rem;">
                <i class="fa-solid fa-comments" style="margin-right: 8px; color: #64748b;"></i> 
                Recenzije knjige
            </h4>
            <button class="close-modal" onclick="closeCommentModal()">&times;</button>
        </div>

        <div class="comments-list-container">
            <% if (book.bookReviews && book.bookReviews.length > 0) { %>
                <% book.bookReviews.forEach(rating => { %>
                    <div class="comment-item">
                        <div class="comment-avatar-circle">
                            <i class="fa-solid fa-user"></i>
                        </div>
                        
                        <div class="comment-content-box">
                            <span class="comment-user-fullname">
                                <%= rating.reviewer ? (rating.reviewer.firstName + ' ' + rating.reviewer.lastName) : 'Anonimni korisnik' %>
                            </span>
                            <p class="comment-text-body">
                                <%= rating.comment || 'Korisnik nije ostavio tekstualni komentar.' %>
                            </p>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 50px 0; color: #94a3b8;">
                    <p style="margin:0;">Nema dostupnih recenzija za ovu knjigu.</p>
                </div>
            <% } %>
        </div>

        <div class="modal-footer" style="padding: 15px 25px; background: #f8fafc; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end;">
            <button type="button" class="btn-secondary" style="padding: 8px 20px;" onclick="closeCommentModal()">Zatvori</button>
        </div>
    </div>
</div>
    
        <% include partials/footer %>
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script src="/javascripts/book.js"></script>
            <script>
                const urlParams = new URLSearchParams(window.location.search);
                if (urlParams.get('success') === 'true') {
                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true,
                    });
                    Toast.fire({
                        icon: 'success',
                        title: 'Akcija uspješna!'
                    });
                    window.history.replaceState({}, document.title, window.location.pathname);
                }
               const roomId = "<%= typeof conversation !== 'undefined' && conversation ? conversation.id : '' %>";

// Provjeravamo da li user postoji (da izbjegnemo grešku ako posjetilac nije ulogovan)
const currentUserId = "<%= typeof user !== 'undefined' && user ? user.id : '' %>";

                function openReportModal() {
                    document.getElementById('reportModal').style.display = 'flex';
                }

                function closeReportModal() {
                    document.getElementById('reportModal').style.display = 'none';
                }

                // Zatvori modal ako se klikne van njega
                window.onclick = function (event) {
                    let modal = document.getElementById('reportModal');
                    if (event.target == modal) {
                        closeReportModal();
                    }
                }

              $(document).ready(function () {
    $('#reportForm').on('submit', function (e) {
        e.preventDefault();

        const formData = {
            reportedUserId: $('input[name="targetId"]').val(), // Ovdje je to zapravo ID knjige
            reason: $('select[name="reason"]').val(),
            description: $('textarea[name="description"]').val(),
            type: 'KNJIGA' // Ključna promjena: Tip je sada KNJIGA
        };

        $.ajax({
            url: '/admin/reports/user', // Koristimo istu rutu jer tvoj kontroler prima te parametre
            method: 'POST',
            data: formData,
            success: function (response) {
                closeReportModal();
                Swal.fire({
                    icon: 'success',
                    title: 'Prijavljeno!',
                    text: 'Hvala vam. Administratori će pregledati ovaj oglas.',
                    confirmButtonColor: '#2563eb'
                });
                $('#reportForm')[0].reset();
            },
            error: function (err) {
                console.error(err);
                Swal.fire('Greška!', 'Došlo je do problema prilikom slanja prijave.', 'error');
            }
        });
    });
});

function openCommentModal() {
    const modal = document.getElementById('commentModal');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden'; // Isključi scroll pozadine
}

function closeCommentModal() {
    const modal = document.getElementById('commentModal');
    modal.style.display = 'none';
    document.body.style.overflow = 'auto'; // Vrati scroll pozadine
}

// Proširi tvoj postojeći window.onclick listener da pokrije oba modala
window.onclick = function (event) {
    const reportModal = document.getElementById('reportModal');
    const commentModal = document.getElementById('commentModal');
    
    if (event.target === reportModal) {
        closeReportModal();
    }
    if (event.target === commentModal) {
        closeCommentModal();
    }
}
            </script>
</body>

</html>