<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Poruke | BookHub</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=1">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel="stylesheet" href="/stylesheets/messages.css" />
    <link rel="stylesheet" href="/stylesheets/footer.css" />
</head>

<body>

    <% include partials/header %>

    <div class="chat-page-wrapper">
        <div class="chat-main-layout">

            <div class="conversations-sidebar">
                <div class="sidebar-header">
                    <h3>Poruke</h3>
                    <span class="chat-badge">
                        <%= conversations.length %> ukupno
                    </span>
                </div>
                <div class="conv-scroll-area">
                    <% conversations.forEach(conv=> { %>
                        <% const isUnread=conv.messages && conv.messages.length> 0; %>

                        <a href="/chat/inbox/<%= conv.id %>" class="conv-link conversation-box 
                            <%= conversation && conv.id == conversation.id ? 'active' : '' %> 
                            <%= !conv.bookId ? 'system-conversation' : '' %>" data-id="<%= conv.id %>">

                            <div class="img-wrapper">
                                <img src="/images/noProfileImage.png" alt="Profil">
                                <% if(isUnread) { %>
                                    <span class="unread-count-badge">
                                        <%= conv.messages.length %>
                                    </span>
                                <% } %>
                            </div>

                            <div class="conversation-info">
                                <div class="info-top">
                                    <h4>
                                        <%= user.id==conv.buyerId ? conv.seller.firstName : conv.buyer.firstName %>
                                    </h4>
                                </div>
                                <p class="<%= isUnread ? 'unread-text' : '' %>">
                                    <% if (conv.book) { %>
                                        <i class="fa-solid fa-book"></i>
                                        <%= conv.book.title %>
                                    <% } else { %>
                                        <i class="fa-solid fa-circle-info"></i> Administracija
                                    <% } %>
                                </p>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>

            <div class="messages-container">
                <% if (conversation) { %>
                    <div class="message-header">
                        <div class="header-user-info">
                            <img src="/images/noProfileImage.png" class="header-avatar" alt="User">
                            <div class="text-details">
                                <a>
                                    <%= user.id==conversation.buyerId ? conversation.seller.firstName + ' ' +
                                        conversation.seller.lastName : conversation.buyer.firstName + ' ' +
                                        conversation.buyer.lastName %>
                                </a>
                                <h6>
                                    <% if (conversation.book) { %>
                                        <i class="fa-solid fa-book"></i>
                                        <%= conversation.book.title %>
                                    <% } else { %>
                                        <i class="fa-solid fa-shield-halved"></i> Sistemska obavijest
                                    <% } %>
                                </h6>
                            </div>
                        </div>
                        <div class="message-header-actions">
                            <% if (conversation.bookId) { %>
                                <a href="/books/details/<%= conversation.bookId %>" class="btn-book-details">Oglas</a>
                            <% } %>
                            
                            <% if (conversation.bookId) { %> 
                                <button type="button" class="btn-report-user" onclick="openReportModal()">
                                    <i class="fa-solid fa-flag"></i> Prijavi
                                </button>
                            <% } %>
                        </div>
                    </div>

                    <div class="messages-list" id="messagesList">
                        <% messages.forEach(message=> { %>
                            <div class="message <%= message.senderId == user.id ? 'outgoing' : 'incoming' %>">
                                <div class="msg-bubble">
                                    <%= message.content %>
                                </div>
                                <span class="msg-time">
                                    <%= new Date(message.createdAt).toLocaleTimeString('en-US', { hour: '2-digit' , minute: '2-digit' }) %>
                                </span>
                            </div>
                        <% }) %>
                    </div>

                    <div class="chat-input-area">
                        <form id="chatForm">
                            <input type="text" placeholder="Napišite poruku..." id="messageInput" autocomplete="off">
                            <button type="submit" class="send-btn">
                                <i class="fa-solid fa-paper-plane"></i>
                                <span>Pošalji</span>
                            </button>
                        </form>
                    </div>
                <% } else { %>
                    <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #888;">
                        <i class="fa-regular fa-comments" style="font-size: 3rem; margin-bottom: 10px;"></i>
                        <p>Odaberite konverzaciju za početak razgovora.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <div id="reportModal" class="report-modal-overlay" style="display: none;">
        <div class="report-modal-card">
            <div class="modal-header">
                <h4><i class="fa-solid fa-triangle-exclamation"></i> Prijavi korisnika</h4>
                <button class="close-modal" onclick="closeReportModal()">&times;</button>
            </div>
            <form id="reportForm">
                <% if(conversation) { %>
                    <input type="hidden" name="reportedUserId" value="<%= user.id == conversation.buyerId ? conversation.sellerId : conversation.buyerId %>">
                <% } %>
                <div class="form-group">
                    <label>Razlog prijave:</label>
                    <select name="reason" required>
                        <option value="">Odaberite razlog...</option>
                        <option value="Prevara">Prevara / Neozbiljan prodavač</option>
                        <option value="Vrijeđanje">Vrijeđanje ili uznemiravanje</option>
                        <option value="Spam">Spam ili lažni oglas</option>
                        <option value="Ostalo">Ostalo</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Opis situacije:</label>
                    <textarea name="description" placeholder="Opišite detaljnije šta se desilo..." required></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn-secondary" onclick="closeReportModal()">Odustani</button>
                    <button type="submit" class="btn-danger">Pošalji prijavu</button>
                </div>
            </form>
        </div>
    </div>

    <% include partials/footer %>


    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="/socket.io/socket.io.js"></script>

    <script>
        
        window.chatConfig = {
            roomId: "<%= conversation ? conversation.id : '' %>",
            currentUserId: "<%= user.id %>"
        };

        
        var roomId = window.chatConfig.roomId;
        var currentUserId = window.chatConfig.currentUserId;
    </script>

    <script src="/javascripts/messages.js"></script>
    
    <script src="/javascripts/chat.js"></script>

</body>
</html>