<!DOCTYPE html>
<html lang="ba">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moje Narudžbine</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel="stylesheet" href="/stylesheets/orders.css" />
</head>

<body>

    <% include partials/header %>

        <div class="ord-main-wrapper">
            <div class="ord-container">
                <div class="ord-header">
                    <h1><i class="fa-solid fa-box-open"></i> Moje Narudžbine</h1>
                    <p>Pregled svih vaših kupovina i statusa isporuke.</p>
                </div>

                <div class="ord-list">
                    <% if (orders && orders.length> 0) { %>
                        <% orders.forEach(order=> { %>
                            <div class="ord-card">
                                <div class="ord-card-header">
                                    <span class="ord-id">ID: #ORD-<%= order.id %></span>
                                    <span class="ord-date">
                                        <%= new Date(order.createdAt).toLocaleDateString('en-US') %>
                                    </span>

                                    <% let statusClass='status-pending' ; if(order.status==='prihvaćeno' )
                                        statusClass='status-completed' ; if(order.status==='odbijeno' ||
                                        order.status==='otkazano' ) statusClass='status-cancelled' ; %>
                                        <span class="ord-status <%= statusClass %>">
                                            <%= order.status %>
                                        </span>
                                </div>

                                <div class="ord-body">
                                    <% order.items.forEach(item=> { %>
                                      <div class="ord-item">
    <img src="<%= item.book.imageUrl || '/images/default-book.png' %>" alt="Knjiga">
    
    <div class="ord-item-info">
        <h3><%= item.book.title %></h3>
        <p>Prodavac: <strong><%= order.seller ? order.seller.firstName + ' ' + order.seller.lastName : 'Nepoznato' %></strong></p>
        <span class="ord-price text-success"><%= item.priceAtPurchase %> KM</span>
    </div>

    <% if(order.status === 'PRIHVAĆENO' || order.status === 'ODBIJENO') { %>
        <button class="ord-btn ord-btn-rate small-btn" 
                onclick="openRatingModal('<%= item.book.id %>', '<%= item.book.title %>', '<%= item.book.sellerId || order.sellerId %>')">
            <i class="fa-regular fa-star"></i> Ocijeni
        </button>
    <% } %>
</div>
                                        <% }) %>

                                            <div class="ord-summary">
                                                <strong>Ukupno: <span style="color: #27ae60;">
                                                        <%= order.totalPrice %> KM
                                                    </span></strong>
                                            </div>

                                            <div class="ord-actions">
                                                <% if(order.status==='NA ČEKANJU' || order.status === 'Na čekanju' ) { %>
                                                    <button class="ord-btn ord-btn-cancel"
                                                        data-id="<%= order.id %>">Otkaži narudžbu</button>
                                                    <% } %>

                                                        <% if(order.status==='PRIHVAĆENO' || order.status==='ODBIJENO' )
                                                            { %>
                                                            <button class="ord-btn ord-btn-contact">
                                                                <i class="fa-regular fa-envelope"></i> Kontaktiraj
                                                                prodavca
                                                            </button>
                                                            <% } %>
                                            </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="no-orders" style="text-align: center; padding: 50px;">
                                        <i class="fa-solid fa-cart-shopping" style="font-size: 4rem; color: #ccc;"></i>
                                        <p style="margin-top: 20px; font-size: 1.2rem; color: #666;">Još uvijek niste
                                            napravili nijednu narudžbu.</p>
                                        <a href="/" class="ord-btn ord-btn-details"
                                            style="display: inline-block; margin-top: 10px; text-decoration: none;">Idi
                                            u prodavnicu</a>
                                    </div>
                                    <% } %>
                </div>
            </div>
        </div>

        <div id="ratingOverlay" class="rating-overlay">
            <div class="rating-modal">
                <div class="rating-header">
                    <h3>Ocijeni kupovinu</h3>

                </div>

                <form id="ratingForm">
                    <input type="hidden" name="bookId" id="modalBookId">
                    <input type="hidden" name="sellerId" id="modalSellerId">

                    <div class="rating-content">
                        <p class="rating-subtitle">Podijelite svoje iskustvo za knjigu: <br> <strong
                                id="modalBookTitle">Naslov Knjige</strong></p>

                        <div class="form-group">
                            <label><i class="fa-solid fa-user-tag"></i> Ocjena za prodavača</label>
                            <select name="sellerRating" id="userRating" required>
                                <option value="" disabled selected>Odaberite ocjenu...</option>
                                <option value="5">⭐⭐⭐⭐⭐ </option>
                                <option value="4">⭐⭐⭐⭐ </option>
                                <option value="3">⭐⭐⭐</option>
                                <option value="2">⭐⭐</option>
                                <option value="1">⭐</option>
                            </select>
                        </div>

                        <div class="form-group">

                            <label><i class="fa-solid fa-book"></i> Ocjena za knjigu</label>
                            <select name="bookRating" id="bookRating" required>
                                <option value="" disabled selected>Odaberite ocjenu...</option>
                                <option value="5">⭐⭐⭐⭐⭐</option>
                                <option value="4">⭐⭐⭐⭐</option>
                                <option value="3">⭐⭐⭐</option>
                                <option value="2">⭐⭐</option>
                                <option value="1">⭐</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label><i class="fa-solid fa-comment"></i> Komentar na knjigu: </label>
                            <textarea id="comment" name="comment" rows="3"
                                placeholder="Napišite kratak dojam..."></textarea>
                        </div>
                    </div>

                    <div class="rating-footer">
                        <button type="button" onclick="closeRatingModal()" class="btn-cancel-rate">Odustani</button>
                        <button type="submit" class="btn-submit-rate">Potvrdi ocjenu</button>
                    </div>
                </form>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="/javascripts/order.js"></script>
        <script src="/javascripts/review.js"></script>



</body>

</html>