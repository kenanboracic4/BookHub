<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dodaj Knjigu | BookHub</title>

    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel='stylesheet' href='/stylesheets/addBook.css' />
</head>
<body>
    <% include partials/header %>

  <div class="up-main-wrapper">
    <div class="up-header-section">
        <h1>Dodaj novu knjigu</h1>
        <p>Popunite detalje ispod kako biste objavili svoj oglas</p>
    </div>

    <div class="up-form-card">
        <form action="/books/add-book" method="POST" enctype="multipart/form-data" class="up-add-book-form">
            
            <div class="up-input-group full-width">
                <label for="title">Naslov knjige</label>
                <input type="text" id="title" name="title" class="up-input-field" required placeholder="Npr. Na Drini ćuprija">
            </div>

            <div class="up-input-group full-width">
                <label for="author">Autor</label>
                <input type="text" id="author" name="author" class="up-input-field" required placeholder="Ime i prezime autora">
            </div>

            <div class="up-input-group">
                <label for="price">Cijena (KM)</label>
                <input type="number" id="price" name="price" step="0.01" class="up-input-field" required placeholder="0.00">
            </div>

            <div class="up-input-group">
                <label for="isExchange">Zamjena: </label>
                <select id="isExchange" name="isExchange" class="up-select-field" required>
                    <option value="false">Ne</option>
                    <option value="true">Da</option>
                </select>
            </div>

            <div class="up-input-group full-width">
                <label for="description">Opis</label>
                <textarea id="description" name="description" rows="4" class="up-textarea-field" required placeholder="Kratak opis stanja knjige..."></textarea>
            </div>

            <div class="up-input-group full-width">
                <label for="image">Slika knjige (Cover)</label>
                <input type="file" id="image" name="image" accept="image/*" class="up-input-field up-file-input" required>
            </div>

            <div class="up-input-group">
                <label for="genre">Žanr</label>
                <select id="genre" name="genreId" class="up-select-field" required>
                    <option value="" disabled selected>Odaberi žanr</option>
                    <% genres.forEach(function(genre) { %>
                        <option value="<%= genre.id %>"><%= genre.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="up-input-group">
                <label for="language">Jezik</label>
                <select id="language" name="languageId" class="up-select-field" required>
                    <option value="" disabled selected>Odaberi jezik</option>
                    <% languages.forEach(function(language) { %>
                        <option value="<%= language.id %>"><%= language.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="up-input-group">
                <label for="condition">Stanje</label>
                <select id="condition" name="conditionId" class="up-select-field" required>
                    <option value="" disabled selected>Novo/Polovno</option>
                    <% conditions.forEach(function(condition) { %>
                        <option value="<%= condition.id %>"><%= condition.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="up-input-group">
                <label for="location">Grad</label>
                <select id="location" name="locationId" class="up-select-field" required>
                    <option value="" disabled selected>Odaberi lokaciju</option>
                    <% locations.forEach(function(location) { %>
                        <option value="<%= location.id %>"><%= location.name %></option>
                    <% }); %>
                </select>
            </div>

            <button type="submit" class="up-btn-submit">Objavi oglas</button>
        </form>
    </div>
</div>
</body>
</html>