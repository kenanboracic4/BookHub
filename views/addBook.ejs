<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dodaj Knjigu | BookHub</title>

    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel='stylesheet' href='/stylesheets/addBook.css' />
</head>
<body>
    <% include partials/header %>

    <div class="add-book-page">
        <div class="header-section">
            <h1>Dodaj novu knjigu</h1>
            <p>Popunite detalje ispod kako biste objavili svoj oglas</p>
        </div>

        <div class="form-container">
            <form action="/books/add-book" method="POST" enctype="multipart/form-data" class="add-book-form">
                
                <div class="full-width">
                    <label for="title">Naslov knjige:</label>
                    <input type="text" id="title" name="title" required placeholder="Npr. Na Drini ćuprija">
                </div>

                <div class="full-width">
                    <label for="author">Autor:</label>
                    <input type="text" id="author" name="author" required placeholder="Ime i prezime autora">
                </div>

                <div class="full-width">
                    <label for="price">Cijena (KM):</label>
                    <input type="number" id="price" name="price" step="0.01" required placeholder="0.00">
                </div>

                <div class="full-width">
                    <label for="description">Opis:</label>
                    <textarea id="description" name="description" rows="5" required placeholder="Kratak opis stanja knjige, radnje ili izdanja..."></textarea>
                </div>

                <div class="full-width">
                    <label for="image">Slika knjige (Cover):</label>
                    <input type="file" id="image" name="image" accept="image/*" required>
                </div>

                <div>
                    <label for="genre">Žanr:</label>
                    <select id="genre" name="genreId" required>
                        <option value="" disabled selected>Odaberi žanr</option>
                        <% genres.forEach(function(genre) { %>
                            <option value="<%= genre.id %>"><%= genre.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div>
                    <label for="language">Jezik:</label>
                    <select id="language" name="languageId" required>
                        <option value="" disabled selected>Odaberi jezik</option>
                        <% languages.forEach(function(language) { %>
                            <option value="<%= language.id %>"><%= language.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div>
                    <label for="condition">Stanje:</label>
                    <select id="condition" name="conditionId" required>
                        <option value="" disabled selected>Novo/Polovno</option>
                        <% conditions.forEach(function(condition) { %>
                            <option value="<%= condition.id %>"><%= condition.name %></option>
                        <% }); %>
                    </select>
                </div>

                <div>
                    <label for="location">Lokacija:</label>
                    <select id="location" name="locationId" required>
                        <option value="" disabled selected>Grad</option>
                        <% locations.forEach(function(location) { %>
                            <option value="<%= location.id %>"><%= location.name %></option>
                        <% }); %>
                    </select>
                </div>

                <button type="submit" class="btn-submit">Objavi oglas</button>
            </form>
        </div>
    </div>
</body>
</html>