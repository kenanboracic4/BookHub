<header>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <div id="sideNav" class="side-nav">
        <div class="side-nav-header">
            <span class="nav-title">Meni</span>
            <a href="javascript:void(0)" class="closebtn" id="closeBtn"><i class="fa-solid fa-xmark"></i></a>
        </div>
        <div class="side-nav-content">
            <a href="/" class="nav-link"><i class="fa-solid fa-house"></i> Početna</a>
            <% if (user) { %>
                <a href="/user/profile/<%= user.id %>" class="nav-link"><i class="fa-solid fa-user"></i> Moj Profil</a>
                <% } %>
                    <a href="/books" class="nav-link"><i class="fa-solid fa-book-open"></i> Oglasi</a>
                    <a href="/books/add-book" class="nav-link highlight"><i class="fa-solid fa-circle-plus"></i> Objavi
                        oglas</a>
                    <% if (user && user.role=='Prodavač' ) { %>
                        <a href="/orders/sales" class="nav-link"><i class="fa-solid fa-box-open"></i> Moje prodaje</a>
                        <% } %>
                            <% if (user && user.role=='Kupac' ) { %>
                                <a href="/orders" class="nav-link"><i class="fa-solid fa-bag-shopping"></i> Moje
                                    narudžbe</a>
                                <% } %>
                                    <% if (user) { %>
                                        <div class="nav-divider"></div>
                                        <a href="/user/logout" class="nav-link logout"><i
                                                class="fa-solid fa-arrow-right-from-bracket"></i> Odjavi se</a>
                                        <% } %>
        </div>
    </div>

    <div id="cartNav" class="side-nav-right">
        <div class="side-nav-header cart-header-bg">
            <div class="cart-header-top">
                <h3>Vaša Korpa <span class="cart-count-bubble">
                        <%= (user && user.cartCount) ? user.cartCount : 0 %>
                    </span></h3>
                <a href="javascript:void(0)" class="closebtn" id="closeCartBtn"><i class="fa-solid fa-xmark"></i></a>
            </div>
            <p class="cart-subtitle">Pregled odabranih knjiga</p>
        </div>
        <div id="cartContent" class="cart-content-area">
            <p class="empty-cart-msg">Vaša korpa je trenutno prazna.</p>
        </div>
        <div class="cart-footer">
            <div class="cart-summary">
                <span class="label">Ukupno za plaćanje:</span>
                <span class="amount" id="cartTotalSum">0.00 KM</span>
            </div>
            <a href="/orders" id="checkoutBtn" class="btn-checkout">Završi kupovinu <i
                    class="fa-solid fa-arrow-right"></i></a>
        </div>
    </div>

    <div id="overlay" class="overlay"></div>

    <div class="main-header">
        <div class="header-container">
            <div class="header-left">
                <button class="menu-toggle" id="menuBtn" aria-label="Open Menu">
                    <i class="fa-solid fa-bars-staggered"></i>
                </button>
            </div>
            <div class="header-center">
                <a href="/" class="logo">
                    <img src="/images/logo.png" alt="BookHub">
                </a>
            </div>
            <div class="header-right">

                <% if(user) { %>
                    <div class="message-wrapper">
                        <a href="/chat" class="icon-btn" id="messageBtn">
                            <i class="fa-solid fa-envelope"></i>
                            <span class="notification-count">
                               <%= messageCount %>
                            </span>
                        </a>
                    </div>
                    <% } %>

                <% if(user && user.role=='Prodavač' ){ %>
                    <div class="notification-wrapper"> <!-- Notifications -->
                        <a href="#" class="icon-btn" id="notifBtn">
                            <i class="fa-solid fa-bell"></i>
                            <span class="notification-count">
                                <%= notificationsCount %>
                            </span>
                        </a>

                        <div class="notification-dropdown" id="notifDropdown">
                            <div class="notif-header">
                                <span>Obavijesti</span>


                            </div>
                            <% if(notifications.length> 0) { %>
                                <div class="notif-list">

                                    <% notifications.forEach(notif=> { %>
                                        <a class="notif-item-link" style="text-decoration: none;"
                                            href="<%= notif.link %>" data-id="<%= notif.id %>">

                                           <div class="notif-item <%= notif.isRead ? 'read' : 'unread' %>">
                                                <div class="notif-icon">
                                                    <% if(notif.type==='order' || notif.type==='Narudžba' ){ %>
                                                        <i class="fa-solid fa-box"></i>
                                                        <% } else if(notif.type==='Ocjena' ){ %>
                                                            <i class="fa-solid fa-star"></i>
                                                            <% } else { %>
                                                                <i class="fa-solid fa-bell"></i>
                                                                <% } %>
                                                </div>
                                                <div class="notif-info">
                                                    <p class="notif-text">
                                                        <%= notif.content %>
                                                    </p>
                                                    <span class="notif-time text-muted">
                                                        <%= new Date(notif.createdAt).toLocaleString() %>
                                                    </span>
                                                </div>
                                            </div>
                                        </a>
                                        <% }) %>
                                </div>
                                <% } else { %>
                                    <div class="no-notifications" style="text-align: center; padding: 50px;">
                                        <span>Nema obavijesti</span>
                                    </div>
                                    <% } %>


                        </div>
                    </div>
                    <% } %>
                        <% if (user) { %>
                            <% if (user.role == 'Kupac') { %>
                            <div class="user-actions">
                                <a href="#" class="icon-btn cart-trigger">
                                    <i class="fa-solid fa-bag-shopping"></i>
                                    <span class="cart-badge-count"
                                        style="display: <%= (user && user.cartCount > 0) ? 'flex' : 'none' %>;">
                                        <%= user.cartCount %>
                                    </span>
                                </a>
                                <% } %>
                                <a href="/user/profile/<%= user.id %>" class="user-pill">
                                    <div class="avatar-circle">
                                        <%= user.firstName.charAt(0) %>
                                    </div>
                                    <span class="desktop-only">
                                        <%= user.firstName %>
                                    </span>
                                </a>
                            </div>
                            <% } else { %>
                                <div class="auth-buttons">
                                    <a href="/user/login" class="btn-ghost">Prijava</a>
                                    <a href="/user/register" class="btn-primary-sm">Registracija</a>
                                </div>
                                <% } %>
            </div>
        </div>

    </div>

    <div class="action-bar-container">
        <div class="action-bar-wrapper">
            <form action="/books/search" method="GET" class="search-filter-form" id="searchForm">
                <div class="search-row">
                    <div class="search-input-group">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" name="q" id="mainSearchInput" placeholder="Pronađi knjigu, autora..."
                            autocomplete="off">
                        <button type="submit" class="inner-search-btn">
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    </div>

                    <button type="button" class="btn-filter-toggle" id="filterToggleBtn">
                        <i class="fa-solid fa-sliders"></i>
                        <span class="desktop-only">Filteri</span>
                    </button>
                </div>

                <div class="filter-dropdown" id="filterPanel">
                    <div class="filter-grid">
                        <div class="filter-group">
                            <label>Cijena (KM)</label>
                            <div class="price-inputs">
                                <input type="number" name="price_min" placeholder="Od" min="0">
                                <span class="separator">-</span>
                                <input type="number" name="price_max" placeholder="Do" min="0">
                            </div>
                        </div>

                        <div class="filter-group">
                            <label>Sortiraj po</label>
                            <select name="sort">
                                <option value="newest">Najnovije</option>
                                <option value="oldest">Najstarije</option>
                                <option value="price_asc">Cijena: Najniža</option>
                                <option value="price_desc">Cijena: Najviša</option>
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Lokacija</label>
                            <select name="location">
                                <option value="">Svi gradovi</option>
                                <% if (typeof locations !=='undefined' ) { %>
                                    <% locations.forEach(loc=> { %>
                                        <option value="<%= loc.id %>">
                                            <%= loc.name %>
                                        </option>
                                        <% }) %>
                                            <% } %>
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Žanr</label>
                            <select name="genre">
                                <option value="">Svi žanrovi</option>
                                <% if (typeof genres !=='undefined' ) { %>
                                    <% genres.forEach(g=> { %>
                                        <option value="<%= g.id %>">
                                            <%= g.name %>
                                        </option>
                                        <% }) %>
                                            <% } %>
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Stanje knjige</label>
                            <select name="condition">
                                <option value="">Sva stanja</option>
                                <% if (typeof conditions !=='undefined' ) { %>
                                    <% conditions.forEach(c=> { %>
                                        <option value="<%= c.id %>">
                                            <%= c.name %>
                                        </option>
                                        <% }) %>
                                            <% } %>
                            </select>
                        </div>

                        <div class="filter-group">
                            <label>Jezik</label>
                            <select name="language">
                                <option value="">Svi jezici</option>
                                <% if (typeof languages !=='undefined' ) { %>
                                    <% languages.forEach(l=> { %>
                                        <option value="<%= l.id %>">
                                            <%= l.name %>
                                        </option>
                                        <% }) %>
                                            <% } %>
                            </select>
                        </div>

                        <div class="filter-actions">
                            <button type="submit" class="btn-apply-filters">Primijeni</button>
                        </div>
                    </div>
                </div>
            </form>

            <a href="/books/add-book" class="btn-action">
                <i class="fa-solid fa-plus"></i>
                <span>Objavi knjigu</span>
            </a>
        </div>
    </div>
</header>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/javascripts/cart.js"></script>
<script src="/javascripts/order.js"></script>
<script src="/javascripts/notifications.js"></script>


<script>
    document.addEventListener('DOMContentLoaded', () => {
        const menuBtn = document.getElementById('menuBtn');
        const closeBtn = document.getElementById('closeBtn');
        const sideNav = document.getElementById('sideNav');

        // Cart elements
        const cartTriggers = document.querySelectorAll('.cart-trigger');
        const cartNav = document.getElementById('cartNav');
        const closeCartBtn = document.getElementById('closeCartBtn');
        const overlay = document.getElementById('overlay');

        // Filter elements
        const filterToggleBtn = document.getElementById('filterToggleBtn');
        const filterPanel = document.getElementById('filterPanel');

        const closeAll = () => {
            sideNav.classList.remove('open');
            cartNav.classList.remove('open');
            overlay.classList.remove('active');

            if (filterPanel.classList.contains('active')) {
                filterPanel.classList.remove('active');
                filterToggleBtn.classList.remove('active');
            }
            document.body.style.overflow = 'auto';
        };

        // Open Left Menu
        menuBtn.addEventListener('click', () => {
            sideNav.classList.add('open');
            overlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        });

        // Open Cart
        cartTriggers.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                cartNav.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';

                if (typeof osvjeziSadrzajKorpe === 'function') {
                    osvjeziSadrzajKorpe();
                }
            });
        });


        filterToggleBtn.addEventListener('click', (e) => {
            e.preventDefault();
            filterPanel.classList.toggle('active');
            filterToggleBtn.classList.toggle('active');
        });

        closeBtn.addEventListener('click', closeAll);
        closeCartBtn.addEventListener('click', closeAll);
        overlay.addEventListener('click', closeAll);

        document.addEventListener('keydown', (e) => {
            if (e.key === "Escape") closeAll();
        });
    });

    // Selektovanje elemenata
    document.addEventListener('DOMContentLoaded', () => {
        const notifBtn = document.getElementById('notifBtn');
        const notifDropdown = document.getElementById('notifDropdown');

        // 1. Klik na zvonce (Toggle)
        if (notifBtn && notifDropdown) {
            notifBtn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation(); // Sprečava window click event da odmah zatvori meni
                notifDropdown.classList.toggle('active');
            });
        }

        // 2. Zatvaranje na klik sa strane
        window.addEventListener('click', (e) => {
            // Provjeravamo da li dropdown uopšte postoji i da li je aktivan
            if (notifDropdown && notifDropdown.classList.contains('active')) {
                // Ako klik NIJE na dugme i NIJE unutar samog dropdown-a, zatvori ga
                if (!notifBtn?.contains(e.target) && !notifDropdown?.contains(e.target)) {
                    notifDropdown.classList.remove('active');
                }
            }
        });

    });
</script>