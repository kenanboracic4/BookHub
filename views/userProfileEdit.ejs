<!DOCTYPE html>
<html>

<head>
    <title>Uredi profil | BookHub</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=1">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel="stylesheet" href="/stylesheets/userProfileEdit.css" />
</head>

<body>

    <% include partials/header %>

        <div class="up-main-wrapper">
            <form id="user-update-form" enctype="multipart/form-data">
                <div class="up-profile-card">
                    <div class="up-header-row">
                        <div class="up-user-info">
                            <div class="up-avatar-wrapper">
                                <img src="<%= targerUser.profileImage || '/images/noProfileImage.png' %>" alt="Profile"
                                    class="up-avatar" id="avatar-preview">
                                <label for="profileImageInput" class="up-avatar-overlay">
                                    <i class="fa-solid fa-camera"></i>
                                </label>
                                <input type="file" id="profileImageInput" name="profileImage" accept="image/*">
                            </div>

                            <div class="up-user-details">
                                <h1>
                                    <%= targerUser.firstName %>
                                        <%= targerUser.lastName %>
                                </h1>
                                <p><i class="fa-solid fa-envelope"></i>
                                    <%= targerUser.email %>
                                </p>
                                <p style="font-size: 0.8rem; margin-top: 5px; color: #94a3b8;">Kliknite na sliku za
                                    promjenu</p>
                            </div>
                        </div>
                        <div class="up-button-group">
                            <a href="/targerUser/profile/<%= user.id %>" class="up-btn up-btn-back">
                                <i class="fa-solid fa-arrow-left"></i> Nazad
                            </a>
                            <button type="submit" class="up-btn up-btn-save">
                                <i class="fa-solid fa-floppy-disk"></i> Sačuvaj
                            </button>
                        </div>
                    </div>

                    <div class="up-data-grid">
                        <div class="up-input-group">
                            <label>Status</label>
                            <% if(user.isAdmin){ %>
                            <select id="status" name="status" class="up-select-field" >
                                  <option value="Aktivan" <%=targerUser.status==='Aktivan' ? 'selected' : '' %>>Aktivan</option>
                                <option value="Neaktivan" <%=targerUser.status==='Neaktivan' ? 'selected' : '' %>>Neaktivan
                                </option>
                            </select>
                                <% } else { %>
                                    <select id="status" name="status" class="up-select-field" disabled>
                                          <option value="Aktivan" <%=user.status==='Aktivan' ? 'selected' : '' %>>Aktivan</option>
                                <option value="Neaktivan" <%=user.status==='Neaktivan' ? 'selected' : '' %>>Neaktivan
                                </option>
                            </select>
                                        <% } %>
                              
                        </div>

                        <div class="up-input-group">
                            <label>Uloga</label>
                            <select id="role" name="role" class="up-select-field" disabled>
                                <option value="Kupac" <%=targerUser.role==='Kupac' ? 'selected' : '' %>>Kupac</option>
                                <option value="Prodavač" <%=targerUser.role==='Prodavač' ? 'selected' : '' %>>Prodavač
                                </option>
                            </select>
                        </div>
                        <div class="up-input-group">
                            <label><i class="fa-solid fa-location-dot"></i> Lokacija</label>
                            <select id="location" name="location" class="up-select-field">
                                <% locations.forEach(function(location) { %>
                                    <option value="<%= location.id %>" <%=(targerUser.location && targerUser.location.id ===
                                        location.id) ? 'selected' : '' %>>
                                        <%= location.name %>
                                    </option>
                                    <% }); %>
                            </select>

                        </div>

                        <div class="up-input-group">
                            <label><i class="fa-solid fa-tags"></i> Žanrovi (CTRL + klik)</label>
                            <select name="genreIds[]" multiple class="up-select-field up-select-multiple">
                                <% genres.forEach(function(genre) { %>
                                    <option value="<%= genre.id %>" <%=(targerUser.Genres && targerUser.Genres.some(g=> g.id ===
                                        genre.id)) ? 'selected' : '' %>>
                                        <%= genre.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>

                        <div class="up-input-group">
                            <label><i class="fa-solid fa-language"></i> Jezici (CTRL + klik)</label>
                            <select name="languageIds[]" multiple class="up-select-field up-select-multiple">
                                <% languages.forEach(function(lang) { %>
                                    <option value="<%= lang.id %>" <%=(targerUser.Languages && targerUser.Languages.some(l=> l.id
                                        === lang.id)) ? 'selected' : '' %>>
                                        <%= lang.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>

                        <div class="up-input-group up-bio-full">
                            <label>Biografija</label>
                            <textarea name="bio" rows="5" class="up-textarea-field"><%= targerUser.bio %></textarea>
                        </div>

                        <div class="up-separator up-bio-full">
                            <span>Promjena šifre:</span>
                        </div>

                        <div class="up-input-group">
                            <label>Nova šifra</label>
                            <input type="password" name="newPassword" class="up-input-field"
                                placeholder="Ostavite prazno ako ne mijenjate">
                        </div>

                        <div class="up-input-group">
                            <label>Potvrdi novu šifru</label>
                            <input type="password" name="confirmPassword" class="up-input-field"
                                placeholder="Potvrdite novu šifru">
                        </div>

                    </div>
                </div>
            </form>
         

        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="/javascripts/user.js"></script>
</body>

</html>