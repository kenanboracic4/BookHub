<!DOCTYPE html>
<html>
  <head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel='stylesheet' href='/stylesheets/card.css' />
  
  </head>
  <body>

    <% include partials/header %>
    
    <div class=" randomBooks">
    <div class="section-title">Slucajno odabrane knjige: </div>
    <div class="containerBooks">
    <% books.forEach((book)=>{ %>
     <%- include('partials/card', {book: book}) %>
    <% }) %>
    </div>
      </div>

        <div class=" randomBooks">
    <div class="section-title">Popularne   knjige: </div>
    <div class="containerBooks">
    <% books.forEach((book)=>{ %>
     <%- include('partials/card', {book: book}) %>
    <% }) %>
    </div>
      </div>

        <div class=" randomBooks">
    <div class="section-title">Preporuceno za vas: </div>
    <div class="containerBooks">
    <% books.forEach((book)=>{ %>
     <%- include('partials/card', {book: book}) %>
    <% }) %>
    </div>
      </div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    const urlParams = new URLSearchParams(window.location.search);
    
    if (urlParams.get('success') === 'true') {
        // Kreiramo Toast konfiguraciju
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end', // Možeš staviti i 'bottom-end' za donji ćošak
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        // Ispucavamo obavještenje
        Toast.fire({
            icon: 'success',
            title: 'Knjiga uspješno dodana!'
        });

        // Čistimo URL
        window.history.replaceState({}, document.title, window.location.pathname);
    }
</script>
</script>
  </body>
</html>
