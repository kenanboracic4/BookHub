<!DOCTYPE html>
<html>

<head>
    <title>Profil | BookHub</title>
    <link rel="icon" type="image/png" href="/images/favicon.png?v=1">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel='stylesheet' href='/stylesheets/header.css' />
    <link rel="stylesheet" href="/stylesheets/userProfile.css" />
    <link rel="stylesheet" href="/stylesheets/footer.css" />
</head>

<body>

    <% include partials/header %>

        <div class="up-main-wrapper">

            <div class="up-profile-card">
                <div class="up-header-row">
                    <div class="up-user-info">
                        <img src="<%= (profileUser.profileImage && profileUser.profileImage !== '') ? profileUser.profileImage : '/images/noProfileImage.png' %>"
                            alt="Profile" class="up-avatar" id="avatar-preview">
                        <div class="up-user-details">
                            <h1>
                                <%= profileUser.firstName %>
                                    <%= profileUser.lastName %>
                            </h1>
                            <p><i class="fa-solid fa-envelope"></i>
                                <%= profileUser.email %>
                            </p>
                            <div class="up-rating">
                                <i id="bd-rating-i" class="fa-solid fa-star"></i>
                                <% if(profileUser.averageRating) { %>
                                    <%= profileUser.averageRating %> / 5
                                    <% } else { %>
                                        N / N
                                        <% } %>
                            </div>
                        </div>
                    </div>
                    <% if(profileUser.id===user.id) { %>
                        <a href="/user/profile/<%= profileUser.id %>/edit" class="up-btn-edit">
                            <i class="fa fa-pen-to-square"></i> Uredi profil
                        </a>
                        <% } %>
                </div>

                <div class="up-data-grid">
                    <div class="up-input-group">
                        <label>Status</label>
                        <div class="up-input-field">
                            <%= profileUser.status %>
                        </div>
                    </div>
                      <div class="up-input-group">
                        <label>Uloga</label>
                        <div class="up-input-field">
                            <%= profileUser.role %>
                        </div>
                        
                    </div>
                    <div class="up-input-group">
                        <label>Lokacija</label>
                        <div class="up-input-field">
                            <%= profileUser.location ? profileUser.location.name : 'Nije navedeno' %>
                        </div>
                        
                    </div>
                    <div class="up-input-group up-bio-full">
                        <label>O meni</label>
                        <textarea class="up-textarea-field" rows="4" readonly
                            disabled><%= profileUser.bio || 'Korisnik nije upisao biografiju.' %></textarea>
                    </div>
                 
                </div>

                <div class="up-preferences">
                    <div class="up-pref-group">
                        <div class="up-input-group">
                            <label><i class="fa-solid fa-book-open"></i> Omiljeni žanrovi</label>
                            <div class="up-tags-wrapper">
                                <% if (profileUser.Genres && profileUser.Genres.length> 0) { %>
                                    <% profileUser.Genres.forEach(genre=> { %>
                                        <span class="up-tag up-tag-genre">
                                            <%= genre.name %>
                                        </span>
                                        <% }) %>
                                            <% } else { %>
                                                <span class="no-data">Nema odabranih žanrova</span>
                                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="up-pref-group">
                        <div class="up-input-group">
                            <label><i class="fa-solid fa-language"></i> Jezici</label>
                            <div class="up-tags-wrapper">
                                <% if (profileUser.Languages && profileUser.Languages.length> 0) { %>
                                    <% profileUser.Languages.forEach(lang=> { %>
                                        <span class="up-tag up-tag-lang">
                                            <%= lang.name %>
                                        </span>
                                        <% }) %>
                                            <% } else { %>
                                                <span class="no-data">Nema odabranih jezika</span>
                                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% if(profileUser.role==='Prodavač' ) { %>
                <div class="up-books-section">

                    <div class="up-controls-wrapper">

                        <div class="up-filters">
                            <select id="statusFilter" class="up-select">
                                <option value="all" <%=filters.status==='all' ? 'selected' : '' %>>Svi statusi</option>
                                <option value="dostupno" <%=filters.status==='dostupno' ? 'selected' : '' %>>Dostupno
                                </option>
                                <option value="prodato" <%=filters.status==='prodato' ? 'selected' : '' %>>Prodato
                                </option>
                            </select>

                            <select id="dateFilter" class="up-select">
                                <option value="" <%=!filters.date ? 'selected' : '' %>>Poredaj po datumu</option>
                                <option value="date-desc" <%=filters.date==='date-desc' ? 'selected' : '' %>>Najnovije
                                    prvo</option>
                                <option value="date-asc" <%=filters.date==='date-asc' ? 'selected' : '' %>>Najstarije
                                    prvo</option>
                            </select>

                            <select id="priceFilter" class="up-select">
                                <option value="" <%=!filters.price ? 'selected' : '' %>>Poredaj po cijeni</option>
                                <option value="price-asc" <%=filters.price==='price-asc' ? 'selected' : '' %>>Cijena:
                                    Najniža prvo</option>
                                <option value="price-desc" <%=filters.price==='price-desc' ? 'selected' : '' %>>Cijena:
                                    Najviša prvo</option>
                            </select>

                            <select id="titleFilter" class="up-select">
                                <option value="" <%=!filters.title ? 'selected' : '' %>>Poredaj po naslovu</option>
                                <option value="title-asc" <%=filters.title==='title-asc' ? 'selected' : '' %>>Naslov: A
                                    → Z</option>
                                <option value="title-desc" <%=filters.title==='title-desc' ? 'selected' : '' %>>Naslov:
                                    Z → A</option>
                            </select>

                            <button id="filterBtn" class="filter-btn">
                                Filtriraj
                            </button>
                        </div>
                    </div>
                    <h2 class="up-section-title">
                        <% if(profileUser.id===user.id) { %> Moji oglasi <% } else { %> Oglasi <%= profileUser.firstName
                                    %>a <% } %>
                                        (<span id="bookCount">
                                            <%= profileUserBooks ? profileUserBooks.length : 0 %>
                                        </span>)
                    </h2>

                    <% if (profileUserBooks && profileUserBooks.length> 0) { %>
                        <div class="up-books-list" id="booksContainer">
                            <% profileUserBooks.forEach(book=> { %>

                                <div class="up-book-row" data-title="<%= book.title.toLowerCase() %>"
                                    data-price="<%= book.price %>" data-date="<%= new Date(book.createdAt).getTime() %>"
                                    data-status="<%= book.status ? book.status.toLowerCase() : 'dostupno' %>">

                                    <div class="up-book-info">
                                        <div class="up-book-img-wrapper">
                                            <img src="<%= book.imageUrl || '/images/default-book.png' %>"
                                                alt="<%= book.title %>">
                                        </div>

                                        <div class="up-book-text">
                                            <h3>
                                                <%= book.title %>
                                            </h3>
                                            <p class="up-book-date">
                                                <i class="fa-regular fa-calendar"></i>
                                                <%= new Date(book.createdAt).toLocaleDateString('bs-BA') %>
                                            </p>
                                            <p class="up-book-price">
                                                <%= parseFloat(book.price).toFixed(2) %> KM
                                            </p>
                                            <% if(book.status) { %>
                                                <span  class="up-mini-status">
                                                    <%= book.status %>
                                                </span>
                                                <% } %>
                                        </div>
                                    </div>
                                    
                                    <% if(user.id===profileUser.id) { %>
                                    <div class="up-book-actions">
                                        <a href="/books/edit/<%= book.id %>" class="up-action-btn up-btn-modify">
                                            <i class="fa fa-pen"></i> Uredi
                                        </a>
                                        <button  id = "up-deleteBtn" class="up-action-btn up-btn-delete" data-id = "<%= book.id %>">
                                            <i class="fa fa-trash"></i> Obriši
                                        </button>
                                    </div>
                                    <% } %>
                                </div>

                                <% }) %>
                        </div>
                        <% } else { %>
                            <% } %>
                </div>
                <% } %>

        </div>

      

        <% include partials/footer %>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        
        <script src="/javascripts/book.js"></script>

        <script src="/javascripts/userProfile.js"></script>
</body>

</html>